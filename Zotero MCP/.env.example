# Zotero MCP Server — Configuration
# Copy this file to .env and fill in your values.

# ── Zotero Web API ──────────────────────────────────────────────────────────
# Your Zotero user ID (numeric). Find it at: https://www.zotero.org/settings/keys
ZOTERO_USER_ID=123456

# API key with read/write access to your library.
# Generate one at: https://www.zotero.org/settings/keys/new
ZOTERO_API_KEY=your_api_key_here

# "user" for a personal library, "group" for a group library.
ZOTERO_LIBRARY_TYPE=user

# ── Better BibTeX (local) ───────────────────────────────────────────────────
# URL for the BBT JSON-RPC endpoint. Default is correct for most installations.
BBT_BASE_URL=http://localhost:23119/better-bibtex

# Seconds to wait when checking if BBT/Zotero is running (keep short to avoid stalls).
BBT_TIMEOUT=3.0

# How long (seconds) to cache the BBT availability result before re-checking.
BBT_CACHE_TTL=30
